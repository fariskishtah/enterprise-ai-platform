{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ESNext",
    "types": ["node"]
  },
  "include": ["tailwind.config.ts", "vite.config.ts"]
}
