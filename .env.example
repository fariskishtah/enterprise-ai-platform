DATABASE_URL=postgresql+psycopg://ai_manufacturing:ai_manufacturing_password@postgres:5432/ai_manufacturing
REDIS_URL=redis://redis:6379/0
SECRET_KEY=replace-with-a-generated-32-byte-secret
ENVIRONMENT=local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# Local Python execution paths. Docker Compose supplies mounted /app/data paths.
MLFLOW_TRACKING_URI=file:../mlruns
MODEL_ARTIFACT_ROOT=../ml/model-artifacts
AI_ARTIFACT_ROOT=../ml/ai-artifacts
AI_DEFAULT_REGISTERED_MODEL_PREFIX=ai_core
TRAINING_QUEUE_NAME=ai-training
TRAINING_JOB_MAX_ATTEMPTS=3
TRAINING_JOB_RETRY_BASE_SECONDS=5
TRAINING_JOB_STALE_AFTER_SECONDS=3600
TRAINING_JOB_ORPHANED_AFTER_SECONDS=60

POSTGRES_DB=ai_manufacturing
POSTGRES_USER=ai_manufacturing
POSTGRES_PASSWORD=ai_manufacturing_password

BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
